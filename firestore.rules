rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return signedIn() && request.auth.token.email != null
        ? request.auth.token.email.lower()
        : '';
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function listOrEmpty(value) {
      return value is list ? value : [];
    }

    function familyDoc(familyId) {
      return get(/databases/$(database)/documents/families/$(familyId));
    }

    function custodyGroupDoc(groupId) {
      return get(/databases/$(database)/documents/custodyGroups/$(groupId));
    }

    function currentUserFamilyInvitationId(familyId) {
      return "family_" + familyId + "_" + userEmail();
    }

    function currentUserFamilyInvitationPath(familyId) {
      return /databases/$(database)/documents/familyInvitations/$(currentUserFamilyInvitationId(familyId));
    }

    function familyExists(familyId) {
      return exists(/databases/$(database)/documents/families/$(familyId));
    }

    function custodyGroupExists(groupId) {
      return exists(/databases/$(database)/documents/custodyGroups/$(groupId));
    }

    function isFamilyMember(familyId) {
      return signedIn()
        && familyExists(familyId)
        && (
          request.auth.uid in listOrEmpty(familyDoc(familyId).data.memberIds)
          || request.auth.uid in listOrEmpty(familyDoc(familyId).data.member_ids)
          || userEmail() in listOrEmpty(familyDoc(familyId).data.memberEmails)
          || userEmail() in listOrEmpty(familyDoc(familyId).data.member_emails)
          || request.auth.uid == familyDoc(familyId).data.ownerId
          || request.auth.uid == familyDoc(familyId).data.owner_id
          || request.auth.uid == familyDoc(familyId).data.adminId
          || request.auth.uid == familyDoc(familyId).data.admin_id
        );
    }

    function isFamilyViewer(familyId) {
      return signedIn()
        && familyExists(familyId)
        && (
          userEmail() in listOrEmpty(familyDoc(familyId).data.viewerEmails)
          || userEmail() in listOrEmpty(familyDoc(familyId).data.viewer_emails)
          || request.auth.uid in listOrEmpty(familyDoc(familyId).data.viewerIds)
          || request.auth.uid in listOrEmpty(familyDoc(familyId).data.viewer_ids)
        );
    }

    function canReadFamily(familyId) {
      return isFamilyMember(familyId) || isFamilyViewer(familyId);
    }

    function canWriteFamily(familyId) {
      return isFamilyMember(familyId);
    }

    function currentUserFamilyInvitationExists(familyId) {
      return signedIn()
        && exists(currentUserFamilyInvitationPath(familyId));
    }

    function currentUserFamilyInvitationAfterStatus(familyId, status) {
      return signedIn()
        && currentUserFamilyInvitationExists(familyId)
        && getAfter(currentUserFamilyInvitationPath(familyId)).data.status == status
        && (
          getAfter(currentUserFamilyInvitationPath(familyId)).data.recipientEmail == userEmail()
          || getAfter(currentUserFamilyInvitationPath(familyId)).data.recipient_email == userEmail()
        );
    }

    function familyMemberEmailsPreserved() {
      return listOrEmpty(request.resource.data.memberEmails)
          .hasAll(listOrEmpty(resource.data.memberEmails))
        && listOrEmpty(request.resource.data.member_emails)
          .hasAll(listOrEmpty(resource.data.member_emails));
    }

    function canAcceptFamilyInvitationUpdate(familyId) {
      return signedIn()
        && familyExists(familyId)
        && (
          userEmail() in listOrEmpty(resource.data.pendingMemberEmails)
          || userEmail() in listOrEmpty(resource.data.pending_member_emails)
        )
        && userEmail() in listOrEmpty(request.resource.data.memberEmails)
        && userEmail() in listOrEmpty(request.resource.data.member_emails)
        && familyMemberEmailsPreserved()
        && currentUserFamilyInvitationAfterStatus(familyId, "accepted")
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "memberEmails",
          "member_emails",
          "pendingMemberEmails",
          "pending_member_emails",
          "members",
          "updatedAt"
        ]);
    }

    function canDeclineFamilyInvitationUpdate(familyId) {
      return signedIn()
        && familyExists(familyId)
        && (
          userEmail() in listOrEmpty(resource.data.pendingMemberEmails)
          || userEmail() in listOrEmpty(resource.data.pending_member_emails)
        )
        && currentUserFamilyInvitationAfterStatus(familyId, "declined")
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "pendingMemberEmails",
          "pending_member_emails",
          "updatedAt"
        ]);
    }

    function isCustodyMember(groupId) {
      return signedIn()
        && custodyGroupExists(groupId)
        && (
          userEmail() in listOrEmpty(custodyGroupDoc(groupId).data.memberEmails)
          || userEmail() in listOrEmpty(custodyGroupDoc(groupId).data.member_emails)
          || request.auth.uid in listOrEmpty(custodyGroupDoc(groupId).data.memberIds)
          || request.auth.uid in listOrEmpty(custodyGroupDoc(groupId).data.member_ids)
          || request.auth.uid == custodyGroupDoc(groupId).data.ownerId
          || request.auth.uid == custodyGroupDoc(groupId).data.owner_id
          || request.auth.uid == custodyGroupDoc(groupId).data.adminId
          || request.auth.uid == custodyGroupDoc(groupId).data.admin_id
        );
    }

    function isCustodyViewer(groupId) {
      return signedIn()
        && custodyGroupExists(groupId)
        && (
          userEmail() in listOrEmpty(custodyGroupDoc(groupId).data.viewerEmails)
          || userEmail() in listOrEmpty(custodyGroupDoc(groupId).data.viewer_emails)
          || request.auth.uid in listOrEmpty(custodyGroupDoc(groupId).data.viewerIds)
          || request.auth.uid in listOrEmpty(custodyGroupDoc(groupId).data.viewer_ids)
        );
    }

    function canReadCustody(groupId) {
      return isCustodyMember(groupId) || isCustodyViewer(groupId);
    }

    function canWriteCustody(groupId) {
      return isCustodyMember(groupId);
    }

    function hasRequestFamilyId() {
      return request.resource.data.familyId is string
        || request.resource.data.family_id is string;
    }

    function hasExistingFamilyId() {
      return resource.data.familyId is string
        || resource.data.family_id is string;
    }

    function requestFamilyId() {
      return request.resource.data.familyId is string
        ? request.resource.data.familyId
        : request.resource.data.family_id;
    }

    function existingFamilyId() {
      return resource.data.familyId is string
        ? resource.data.familyId
        : resource.data.family_id;
    }

    function canReadScopedFamilyDoc() {
      return hasExistingFamilyId()
        && (canReadFamily(existingFamilyId()) || canReadCustody(existingFamilyId()));
    }

    function canCreateScopedFamilyDoc() {
      return hasRequestFamilyId()
        && (canWriteFamily(requestFamilyId()) || canWriteCustody(requestFamilyId()));
    }

    function canUpdateScopedFamilyDoc() {
      return hasRequestFamilyId()
        && hasExistingFamilyId()
        && requestFamilyId() == existingFamilyId()
        && (canWriteFamily(existingFamilyId()) || canWriteCustody(existingFamilyId()));
    }

    function canDeleteScopedFamilyDoc() {
      return canWriteFamily(existingFamilyId()) || canWriteCustody(existingFamilyId());
    }

    match /users/{userId} {
      allow read, create, update: if isOwner(userId);
      allow delete: if false;
    }

    match /families/{familyId} {
      allow read: if canReadFamily(familyId);
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if canWriteFamily(familyId)
        || canAcceptFamilyInvitationUpdate(familyId)
        || canDeclineFamilyInvitationUpdate(familyId);
      allow delete: if signedIn()
        && (
          request.auth.uid == resource.data.ownerId
          || request.auth.uid == resource.data.owner_id
        );
    }

    match /custodyGroups/{groupId} {
      allow read: if canReadCustody(groupId);
      allow create: if signedIn()
        && (
          request.auth.uid == request.resource.data.ownerId
          || request.auth.uid == request.resource.data.owner_id
          || userEmail() in listOrEmpty(request.resource.data.memberEmails)
          || userEmail() in listOrEmpty(request.resource.data.member_emails)
        );
      allow update: if canWriteCustody(groupId);
      allow delete: if signedIn()
        && (
          request.auth.uid == resource.data.ownerId
          || request.auth.uid == resource.data.owner_id
        );
    }

    match /custodyDays/{docId} {
      allow read: if canReadScopedFamilyDoc();
      allow create: if canCreateScopedFamilyDoc();
      allow update: if canUpdateScopedFamilyDoc();
      allow delete: if canDeleteScopedFamilyDoc();
    }

    match /custodySpecialEvents/{docId} {
      allow read: if canReadScopedFamilyDoc();
      allow create: if canCreateScopedFamilyDoc()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if canUpdateScopedFamilyDoc();
      allow delete: if canDeleteScopedFamilyDoc();
    }

    match /custodyTravelPlans/{docId} {
      allow read: if canReadScopedFamilyDoc();
      allow create: if canCreateScopedFamilyDoc()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if canUpdateScopedFamilyDoc();
      allow delete: if canDeleteScopedFamilyDoc();
    }

    match /custodyExchanges/{docId} {
      allow read: if canReadScopedFamilyDoc();
      allow create: if canCreateScopedFamilyDoc()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if canUpdateScopedFamilyDoc();
      allow delete: if canDeleteScopedFamilyDoc();
    }

    match /custodyPackingItems/{docId} {
      allow read: if canReadScopedFamilyDoc();
      allow create: if canCreateScopedFamilyDoc()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if canUpdateScopedFamilyDoc();
      allow delete: if canDeleteScopedFamilyDoc();
    }

    match /custodyExpenses/{docId} {
      allow read: if canReadScopedFamilyDoc();
      allow create: if canCreateScopedFamilyDoc()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if canUpdateScopedFamilyDoc();
      allow delete: if canDeleteScopedFamilyDoc();
    }

    match /custodyNotificationPrefs/{scopeId} {
      allow read: if canReadFamily(scopeId) || canReadCustody(scopeId);
      allow create, update: if hasRequestFamilyId()
        && requestFamilyId() == scopeId
        && (canWriteFamily(scopeId) || canWriteCustody(scopeId));
      allow delete: if canWriteFamily(scopeId) || canWriteCustody(scopeId);
    }

    match /familyEvents/{docId} {
      allow read: if canReadScopedFamilyDoc();
      allow create: if canCreateScopedFamilyDoc();
      allow update: if canUpdateScopedFamilyDoc();
      allow delete: if canDeleteScopedFamilyDoc();
    }

    match /familyActivity/{docId} {
      allow read: if canReadScopedFamilyDoc();
      allow create: if canCreateScopedFamilyDoc()
        && (
          request.resource.data.createdBy == request.auth.uid
          || request.resource.data.actorId == request.auth.uid
        );
      allow update: if false;
      allow delete: if canDeleteScopedFamilyDoc();
    }

    match /familyInvitations/{docId} {
      allow read: if canReadScopedFamilyDoc()
        || (
          signedIn()
          && (
            userEmail() == resource.data.recipientEmail
            || userEmail() == resource.data.recipient_email
          )
        );
      allow create: if canCreateScopedFamilyDoc()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if canUpdateScopedFamilyDoc()
        || (
          signedIn()
          && hasExistingFamilyId()
          && hasRequestFamilyId()
          && requestFamilyId() == existingFamilyId()
          && (
            userEmail() == resource.data.recipientEmail
            || userEmail() == resource.data.recipient_email
          )
          && request.resource.data.familyId == resource.data.familyId
          && request.resource.data.family_id == resource.data.family_id
          && request.resource.data.recipientEmail == resource.data.recipientEmail
          && request.resource.data.recipient_email == resource.data.recipient_email
          && request.resource.data.status in ["accepted", "declined"]
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "status",
            "acceptedBy",
            "accepted_by",
            "acceptedAt",
            "accepted_at",
            "declinedBy",
            "declined_by",
            "declinedAt",
            "declined_at",
            "updatedAt",
            "updated_at"
          ])
        );
      allow delete: if canDeleteScopedFamilyDoc();
    }

    match /familyLists/{docId} {
      allow read: if canReadScopedFamilyDoc();
      allow create: if canCreateScopedFamilyDoc();
      allow update: if canUpdateScopedFamilyDoc();
      allow delete: if canDeleteScopedFamilyDoc();
    }

    match /familyListItems/{docId} {
      allow read: if canReadScopedFamilyDoc();
      allow create: if canCreateScopedFamilyDoc();
      allow update: if canUpdateScopedFamilyDoc();
      allow delete: if canDeleteScopedFamilyDoc();
    }

    match /familyPantryItems/{docId} {
      allow read: if canReadScopedFamilyDoc();
      allow create: if canCreateScopedFamilyDoc();
      allow update: if canUpdateScopedFamilyDoc();
      allow delete: if canDeleteScopedFamilyDoc();
    }

    match /mealTemplates/{docId} {
      allow read: if canReadScopedFamilyDoc();
      allow create: if canCreateScopedFamilyDoc();
      allow update: if canUpdateScopedFamilyDoc();
      allow delete: if canDeleteScopedFamilyDoc();
    }

    match /tasks/{docId} {
      allow read: if canReadScopedFamilyDoc();
      allow create: if canCreateScopedFamilyDoc();
      allow update: if canUpdateScopedFamilyDoc();
      allow delete: if canDeleteScopedFamilyDoc();
    }

    match /taskTemplates/{docId} {
      allow read: if canReadScopedFamilyDoc();
      allow create: if canCreateScopedFamilyDoc();
      allow update: if canUpdateScopedFamilyDoc();
      allow delete: if canDeleteScopedFamilyDoc();
    }

    match /routineRuns/{docId} {
      allow read: if canReadScopedFamilyDoc();
      allow create: if canCreateScopedFamilyDoc();
      allow update: if canUpdateScopedFamilyDoc();
      allow delete: if canDeleteScopedFamilyDoc();
    }

    match /rewards/{docId} {
      allow read: if canReadScopedFamilyDoc();
      allow create: if canCreateScopedFamilyDoc();
      allow update: if canUpdateScopedFamilyDoc();
      allow delete: if canDeleteScopedFamilyDoc();
    }

    match /children/{docId} {
      allow read: if canReadScopedFamilyDoc();
      allow create: if canCreateScopedFamilyDoc();
      allow update: if canUpdateScopedFamilyDoc();
      allow delete: if canDeleteScopedFamilyDoc();
    }

    match /familyMembers/{docId} {
      allow read: if canReadScopedFamilyDoc();
      allow create: if canCreateScopedFamilyDoc();
      allow update: if canUpdateScopedFamilyDoc();
      allow delete: if canDeleteScopedFamilyDoc();
    }

    match /meals/{docId} {
      allow read: if canReadScopedFamilyDoc();
      allow create: if canCreateScopedFamilyDoc();
      allow update: if canUpdateScopedFamilyDoc();
      allow delete: if canDeleteScopedFamilyDoc();
    }

    match /groceries/{docId} {
      allow read: if canReadScopedFamilyDoc();
      allow create: if canCreateScopedFamilyDoc();
      allow update: if canUpdateScopedFamilyDoc();
      allow delete: if canDeleteScopedFamilyDoc();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
