rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return signedIn() && request.auth.token.email != null
        ? request.auth.token.email.lower()
        : "";
    }

    function listOrEmpty(value) {
      return value is list ? value : [];
    }

    function mapOrEmpty(value) {
      return value is map ? value : {};
    }

    function mapList(data, field) {
      return listOrEmpty(mapOrEmpty(data).get(field, []));
    }

    function accessAllowsRead(access) {
      return access is map
        && (
          access.read == true
          || access.write == true
          || access.visible == true
          || access.assignable == true
        );
    }

    function accessAllowsWrite(access) {
      return access is map
        && access.write == true;
    }

    function familyPath(familyId) {
      return /databases/$(database)/documents/families/$(familyId);
    }

    function custodyGroupPath(groupId) {
      return /databases/$(database)/documents/custodyGroups/$(groupId);
    }

    function familyExists(familyId) {
      return signedIn()
        && familyId is string
        && exists(familyPath(familyId));
    }

    function custodyGroupExists(groupId) {
      return signedIn()
        && groupId is string
        && exists(custodyGroupPath(groupId));
    }

    function familyDoc(familyId) {
      return get(familyPath(familyId));
    }

    function custodyGroupDoc(groupId) {
      return get(custodyGroupPath(groupId));
    }

    function isFamilyOwner(familyId) {
      return familyExists(familyId)
        && (
          request.auth.uid == familyDoc(familyId).data.ownerId
          || request.auth.uid == familyDoc(familyId).data.owner_id
          || request.auth.uid == familyDoc(familyId).data.createdBy
          || request.auth.uid == familyDoc(familyId).data.created_by
          || userEmail() == familyDoc(familyId).data.ownerEmail
          || userEmail() == familyDoc(familyId).data.owner_email
          || userEmail() == familyDoc(familyId).data.createdByEmail
          || userEmail() == familyDoc(familyId).data.created_by_email
          || userEmail() == familyDoc(familyId).data.created_by
        );
    }

    function isFamilyAdmin(familyId) {
      return isFamilyOwner(familyId)
        || request.auth.uid in listOrEmpty(familyDoc(familyId).data.adminIds)
        || request.auth.uid in listOrEmpty(familyDoc(familyId).data.admin_ids)
        || userEmail() in listOrEmpty(familyDoc(familyId).data.adminEmails)
        || userEmail() in listOrEmpty(familyDoc(familyId).data.admin_emails);
    }

    function isFamilyMember(familyId) {
      return isFamilyAdmin(familyId)
        || request.auth.uid in listOrEmpty(familyDoc(familyId).data.memberIds)
        || request.auth.uid in listOrEmpty(familyDoc(familyId).data.member_ids)
        || userEmail() in listOrEmpty(familyDoc(familyId).data.memberEmails)
        || userEmail() in listOrEmpty(familyDoc(familyId).data.member_emails);
    }

    function isFamilyViewer(familyId) {
      return isFamilyMember(familyId)
        || request.auth.uid in listOrEmpty(familyDoc(familyId).data.viewerIds)
        || request.auth.uid in listOrEmpty(familyDoc(familyId).data.viewer_ids)
        || userEmail() in listOrEmpty(familyDoc(familyId).data.viewerEmails)
        || userEmail() in listOrEmpty(familyDoc(familyId).data.viewer_emails);
    }

    function canReadFamily(familyId) {
      return isFamilyViewer(familyId);
    }

    function canReadBootstrapFamily(familyId) {
      return signedIn()
        && familyId == "family_" + request.auth.uid;
    }

    function moduleReaderIds(data, moduleName) {
      return mapList(data, moduleName + "ReaderIds");
    }

    function moduleWriterIds(data, moduleName) {
      return mapList(data, moduleName + "WriterIds");
    }

    function moduleReaderEmails(data, moduleName) {
      return mapList(data, moduleName + "ReaderEmails");
    }

    function moduleWriterEmails(data, moduleName) {
      return mapList(data, moduleName + "WriterEmails");
    }

    function hasModulePolicy(data, moduleName) {
      return mapOrEmpty(data).keys().hasAny([
        moduleName + "ReaderIds",
        moduleName + "WriterIds",
        moduleName + "ReaderEmails",
        moduleName + "WriterEmails",
        moduleName + "_reader_ids",
        moduleName + "_writer_ids",
        moduleName + "_reader_emails",
        moduleName + "_writer_emails"
      ]);
    }

    function hasModuleReadGrant(data, moduleName) {
      return request.auth.uid in moduleReaderIds(data, moduleName)
        || request.auth.uid in moduleWriterIds(data, moduleName)
        || userEmail() in moduleReaderEmails(data, moduleName)
        || userEmail() in moduleWriterEmails(data, moduleName)
        || request.auth.uid in mapList(data, moduleName + "_reader_ids")
        || request.auth.uid in mapList(data, moduleName + "_writer_ids")
        || userEmail() in mapList(data, moduleName + "_reader_emails")
        || userEmail() in mapList(data, moduleName + "_writer_emails");
    }

    function hasModuleWriteGrant(data, moduleName) {
      return request.auth.uid in moduleWriterIds(data, moduleName)
        || userEmail() in moduleWriterEmails(data, moduleName)
        || request.auth.uid in mapList(data, moduleName + "_writer_ids")
        || userEmail() in mapList(data, moduleName + "_writer_emails");
    }

    function canReadFamilyModule(familyId, moduleName) {
      return isFamilyAdmin(familyId)
        || (
          familyExists(familyId)
          && (
            hasModuleReadGrant(familyDoc(familyId).data, moduleName)
            || (
              isFamilyMember(familyId)
              && !hasModulePolicy(familyDoc(familyId).data, moduleName)
            )
          )
        );
    }

    function canWriteFamilyModule(familyId, moduleName) {
      return isFamilyAdmin(familyId)
        || (
          familyExists(familyId)
          && (
            hasModuleWriteGrant(familyDoc(familyId).data, moduleName)
            || (
              isFamilyMember(familyId)
              && !hasModulePolicy(familyDoc(familyId).data, moduleName)
            )
          )
        );
    }

    function canWriteFamilyContent(familyId) {
      return isFamilyMember(familyId);
    }

    function canManageFamily(familyId) {
      return isFamilyAdmin(familyId);
    }

    function isCustodyOwner(familyId) {
      return custodyGroupExists(familyId)
        && (
          request.auth.uid == custodyGroupDoc(familyId).data.ownerId
          || request.auth.uid == custodyGroupDoc(familyId).data.owner_id
          || request.auth.uid == custodyGroupDoc(familyId).data.createdBy
          || request.auth.uid == custodyGroupDoc(familyId).data.created_by
          || userEmail() == custodyGroupDoc(familyId).data.ownerEmail
          || userEmail() == custodyGroupDoc(familyId).data.owner_email
          || userEmail() == custodyGroupDoc(familyId).data.createdByEmail
          || userEmail() == custodyGroupDoc(familyId).data.created_by_email
          || userEmail() == custodyGroupDoc(familyId).data.created_by
        );
    }

    function isCustodyAdmin(familyId) {
      return custodyGroupExists(familyId)
        && (
          isCustodyOwner(familyId)
          || request.auth.uid == custodyGroupDoc(familyId).data.owner_id
          || request.auth.uid == custodyGroupDoc(familyId).data.createdBy
          || request.auth.uid == custodyGroupDoc(familyId).data.created_by
          || request.auth.uid in listOrEmpty(custodyGroupDoc(familyId).data.adminIds)
          || request.auth.uid in listOrEmpty(custodyGroupDoc(familyId).data.admin_ids)
          || userEmail() == custodyGroupDoc(familyId).data.ownerEmail
          || userEmail() == custodyGroupDoc(familyId).data.owner_email
          || userEmail() == custodyGroupDoc(familyId).data.createdByEmail
          || userEmail() == custodyGroupDoc(familyId).data.created_by_email
          || userEmail() in listOrEmpty(custodyGroupDoc(familyId).data.adminEmails)
          || userEmail() in listOrEmpty(custodyGroupDoc(familyId).data.admin_emails)
        );
    }

    function canManageCustodyGroup(familyId) {
      return isCustodyAdmin(familyId);
    }

    function isCustodyMember(familyId) {
      return isCustodyAdmin(familyId)
        || request.auth.uid in listOrEmpty(custodyGroupDoc(familyId).data.memberIds)
        || request.auth.uid in listOrEmpty(custodyGroupDoc(familyId).data.member_ids)
        || userEmail() in listOrEmpty(custodyGroupDoc(familyId).data.memberEmails)
        || userEmail() in listOrEmpty(custodyGroupDoc(familyId).data.member_emails);
    }

    function isCustodyViewer(familyId) {
      return isCustodyMember(familyId)
        || request.auth.uid in listOrEmpty(custodyGroupDoc(familyId).data.viewerIds)
        || request.auth.uid in listOrEmpty(custodyGroupDoc(familyId).data.viewer_ids)
        || userEmail() in listOrEmpty(custodyGroupDoc(familyId).data.viewerEmails)
        || userEmail() in listOrEmpty(custodyGroupDoc(familyId).data.viewer_emails)
        || request.auth.uid in listOrEmpty(custodyGroupDoc(familyId).data.custodyReaderIds)
        || request.auth.uid in listOrEmpty(custodyGroupDoc(familyId).data.custody_reader_ids)
        || request.auth.uid in listOrEmpty(custodyGroupDoc(familyId).data.custodyWriterIds)
        || request.auth.uid in listOrEmpty(custodyGroupDoc(familyId).data.custody_writer_ids)
        || userEmail() in listOrEmpty(custodyGroupDoc(familyId).data.custodyReaderEmails)
        || userEmail() in listOrEmpty(custodyGroupDoc(familyId).data.custody_reader_emails)
        || userEmail() in listOrEmpty(custodyGroupDoc(familyId).data.custodyWriterEmails)
        || userEmail() in listOrEmpty(custodyGroupDoc(familyId).data.custody_writer_emails);
    }

    function custodyGroupFamilyId(familyId) {
      return custodyGroupDoc(familyId).data.familyId is string
        ? custodyGroupDoc(familyId).data.familyId
        : custodyGroupDoc(familyId).data.family_id is string
        ? custodyGroupDoc(familyId).data.family_id
        : custodyGroupDoc(familyId).data.householdFamilyId is string
        ? custodyGroupDoc(familyId).data.householdFamilyId
        : custodyGroupDoc(familyId).data.household_family_id is string
        ? custodyGroupDoc(familyId).data.household_family_id
        : "";
    }

    function canReadCustodyFromLinkedFamily(familyId) {
      return custodyGroupExists(familyId)
        && custodyGroupFamilyId(familyId) != ""
        && familyExists(custodyGroupFamilyId(familyId))
        && (
          canManageFamily(custodyGroupFamilyId(familyId))
          || hasModuleReadGrant(familyDoc(custodyGroupFamilyId(familyId)).data, "custody")
          || hasModuleWriteGrant(familyDoc(custodyGroupFamilyId(familyId)).data, "custody")
        );
    }

    function canWriteCustodyFromLinkedFamily(familyId) {
      return custodyGroupExists(familyId)
        && custodyGroupFamilyId(familyId) != ""
        && familyExists(custodyGroupFamilyId(familyId))
        && (
          canManageFamily(custodyGroupFamilyId(familyId))
          || hasModuleWriteGrant(familyDoc(custodyGroupFamilyId(familyId)).data, "custody")
        );
    }

    function canReadCustody(familyId) {
      return isCustodyAdmin(familyId)
        || isCustodyViewer(familyId)
        || canReadCustodyFromLinkedFamily(familyId)
        || (
          familyExists(familyId)
          && canReadFamilyModule(familyId, "custody")
        )
        || (
          custodyGroupExists(familyId)
          && hasModuleReadGrant(custodyGroupDoc(familyId).data, "custody")
        );
    }

    function canWriteCustody(familyId) {
      return isCustodyAdmin(familyId)
        || canWriteCustodyFromLinkedFamily(familyId)
        || (
          familyExists(familyId)
          && canWriteFamilyModule(familyId, "custody")
        )
        || (
          custodyGroupExists(familyId)
          && hasModuleWriteGrant(custodyGroupDoc(familyId).data, "custody")
        );
    }

    function canReadCustodyBudget(familyId) {
      return isCustodyAdmin(familyId)
        || (
          custodyGroupExists(familyId)
          && hasModuleReadGrant(custodyGroupDoc(familyId).data, "budget")
        );
    }

    function canWriteCustodyBudget(familyId) {
      return isCustodyAdmin(familyId)
        || (
          custodyGroupExists(familyId)
          && hasModuleWriteGrant(custodyGroupDoc(familyId).data, "budget")
        );
    }

    function hasRequestFamilyId() {
      return request.resource.data.familyId is string
        || request.resource.data.family_id is string;
    }

    function hasExistingFamilyId() {
      return resource.data.familyId is string
        || resource.data.family_id is string;
    }

    function requestFamilyId() {
      return request.resource.data.familyId is string
        ? request.resource.data.familyId
        : request.resource.data.family_id;
    }

    function existingFamilyId() {
      return resource.data.familyId is string
        ? resource.data.familyId
        : resource.data.family_id;
    }

    function hasRequestCustodyScopeId() {
      return request.resource.data.custodyGroupId is string
        || request.resource.data.familyId is string;
    }

    function hasExistingCustodyScopeId() {
      return resource.data.custodyGroupId is string
        || resource.data.familyId is string;
    }

    function hasRequestExplicitCustodyGroupId() {
      return request.resource.data.custodyGroupId is string;
    }

    function hasExistingExplicitCustodyGroupId() {
      return resource.data.custodyGroupId is string;
    }

    function requestCustodyScopeId() {
      return request.resource.data.custodyGroupId is string
        ? request.resource.data.custodyGroupId
        : request.resource.data.familyId;
    }

    function existingCustodyScopeId() {
      return resource.data.custodyGroupId is string
        ? resource.data.custodyGroupId
        : resource.data.familyId;
    }

    function canReadHouseholdDoc() {
      return hasExistingFamilyId()
        && canReadFamily(existingFamilyId());
    }

    function canReadHouseholdModuleDoc(moduleName) {
      return hasExistingFamilyId()
        && canReadFamilyModule(existingFamilyId(), moduleName);
    }

    function canCreateHouseholdDoc() {
      return hasRequestFamilyId()
        && canWriteFamilyContent(requestFamilyId());
    }

    function canCreateHouseholdModuleDoc(moduleName) {
      return hasRequestFamilyId()
        && canWriteFamilyModule(requestFamilyId(), moduleName);
    }

    function canUpdateHouseholdDoc() {
      return hasRequestFamilyId()
        && hasExistingFamilyId()
        && requestFamilyId() == existingFamilyId()
        && canWriteFamilyContent(existingFamilyId());
    }

    function canUpdateHouseholdModuleDoc(moduleName) {
      return hasRequestFamilyId()
        && hasExistingFamilyId()
        && requestFamilyId() == existingFamilyId()
        && canWriteFamilyModule(existingFamilyId(), moduleName);
    }

    function canDeleteHouseholdDoc() {
      return hasExistingFamilyId()
        && canWriteFamilyContent(existingFamilyId());
    }

    function canDeleteHouseholdModuleDoc(moduleName) {
      return hasExistingFamilyId()
        && canWriteFamilyModule(existingFamilyId(), moduleName);
    }

    function canReadAnyScopedDoc() {
      return (
          hasExistingExplicitCustodyGroupId()
          && canReadCustody(existingCustodyScopeId())
        )
        || (
          !hasExistingExplicitCustodyGroupId()
          && hasExistingFamilyId()
          && (
            canReadFamilyModule(existingFamilyId(), "home")
            || canReadCustody(existingFamilyId())
          )
        );
    }

    function canCreateAnyScopedDoc() {
      return (
          hasRequestExplicitCustodyGroupId()
          && (
            (
              request.resource.data.get("module", "custody") == "budget"
              && canWriteCustodyBudget(requestCustodyScopeId())
            )
            || (
              request.resource.data.get("module", "custody") != "budget"
              && canWriteCustody(requestCustodyScopeId())
            )
          )
        )
        || (
          !hasRequestExplicitCustodyGroupId()
          && hasRequestFamilyId()
          && canWriteFamilyModule(
            requestFamilyId(),
            request.resource.data.get("module", "home")
          )
        );
    }

    function canUpdateAnyScopedDoc() {
      return (
          hasExistingExplicitCustodyGroupId()
          && hasRequestCustodyScopeId()
          && requestCustodyScopeId() == existingCustodyScopeId()
          && canWriteCustody(existingCustodyScopeId())
        )
        || (
          !hasExistingExplicitCustodyGroupId()
          && hasRequestFamilyId()
          && hasExistingFamilyId()
          && requestFamilyId() == existingFamilyId()
          && (
            canWriteFamilyModule(existingFamilyId(), "home")
            || canWriteCustody(existingFamilyId())
          )
        );
    }

    function canDeleteAnyScopedDoc() {
      return (
          hasExistingExplicitCustodyGroupId()
          && canWriteCustody(existingCustodyScopeId())
        )
        || (
          !hasExistingExplicitCustodyGroupId()
          && hasExistingFamilyId()
          && (
            canWriteFamilyModule(existingFamilyId(), "home")
            || canWriteCustody(existingFamilyId())
          )
        );
    }

    function canReadCustodyDoc() {
      return hasExistingCustodyScopeId()
        && canReadCustody(existingCustodyScopeId());
    }

    function canCreateCustodyDoc() {
      return hasRequestCustodyScopeId()
        && canWriteCustody(requestCustodyScopeId());
    }

    function canUpdateCustodyDoc() {
      return hasRequestCustodyScopeId()
        && hasExistingCustodyScopeId()
        && requestCustodyScopeId() == existingCustodyScopeId()
        && canWriteCustody(existingCustodyScopeId());
    }

    function canDeleteCustodyDoc() {
      return hasExistingCustodyScopeId()
        && (
          canWriteCustody(existingCustodyScopeId())
          || canManageCustodyGroup(existingCustodyScopeId())
        );
    }

    function canReadBudgetDoc() {
      return hasExistingCustodyScopeId()
        && canReadCustodyBudget(existingCustodyScopeId());
    }

    function canCreateBudgetDoc() {
      return hasRequestCustodyScopeId()
        && canWriteCustodyBudget(requestCustodyScopeId());
    }

    function canUpdateBudgetDoc() {
      return hasRequestCustodyScopeId()
        && hasExistingCustodyScopeId()
        && requestCustodyScopeId() == existingCustodyScopeId()
        && canWriteCustodyBudget(existingCustodyScopeId());
    }

    function canDeleteBudgetDoc() {
      return hasExistingCustodyScopeId()
        && (
          canWriteCustodyBudget(existingCustodyScopeId())
          || canManageCustodyGroup(existingCustodyScopeId())
        );
    }

    function currentUserFamilyInvitationId(familyId) {
      return "family_" + familyId + "_" + userEmail();
    }

    function currentUserFamilyInvitationPath(familyId) {
      return /databases/$(database)/documents/familyInvitations/$(currentUserFamilyInvitationId(familyId));
    }

    function currentUserCustodyInvitationId(groupId) {
      return "custody_" + groupId + "_" + userEmail();
    }

    function currentUserCustodyInvitationPath(groupId) {
      return /databases/$(database)/documents/custodyInvitations/$(currentUserCustodyInvitationId(groupId));
    }

    function currentUserFamilyInvitationAfterStatus(familyId, status) {
      return signedIn()
        && exists(currentUserFamilyInvitationPath(familyId))
        && getAfter(currentUserFamilyInvitationPath(familyId)).data.status == status
        && getAfter(currentUserFamilyInvitationPath(familyId)).data.recipientEmail == userEmail();
    }

    function currentUserFamilyInvitationAfterGrantsAdmin(familyId) {
      return currentUserFamilyInvitationAfterStatus(familyId, "accepted")
        && (
          getAfter(currentUserFamilyInvitationPath(familyId)).data.admin == true
          || getAfter(currentUserFamilyInvitationPath(familyId)).data.isAdmin == true
          || getAfter(currentUserFamilyInvitationPath(familyId)).data.is_admin == true
          || getAfter(currentUserFamilyInvitationPath(familyId)).data.appRole == "admin"
          || getAfter(currentUserFamilyInvitationPath(familyId)).data.app_role == "admin"
        );
    }

    function invitationModuleAccess(familyId, moduleName, sourceField) {
      return mapOrEmpty(mapOrEmpty(getAfter(currentUserFamilyInvitationPath(familyId)).data.get(sourceField, {})).get(moduleName, {}));
    }

    function currentUserFamilyInvitationModuleCanRead(familyId, moduleName) {
      return accessAllowsRead(invitationModuleAccess(familyId, moduleName, "permissions"))
        || accessAllowsRead(invitationModuleAccess(familyId, moduleName, "modules"));
    }

    function currentUserFamilyInvitationModuleCanWrite(familyId, moduleName) {
      return accessAllowsWrite(invitationModuleAccess(familyId, moduleName, "permissions"))
        || accessAllowsWrite(invitationModuleAccess(familyId, moduleName, "modules"));
    }

    function currentUserCustodyInvitationModuleCanRead(groupId, moduleName) {
      return accessAllowsRead(mapOrEmpty(mapOrEmpty(getAfter(currentUserCustodyInvitationPath(groupId)).data.get("permissions", {})).get(moduleName, {})));
    }

    function currentUserCustodyInvitationModuleCanWrite(groupId, moduleName) {
      return accessAllowsWrite(mapOrEmpty(mapOrEmpty(getAfter(currentUserCustodyInvitationPath(groupId)).data.get("permissions", {})).get(moduleName, {})));
    }

    function listPreserved(after, before) {
      return listOrEmpty(after).hasAll(listOrEmpty(before))
        && listOrEmpty(after).hasOnly(listOrEmpty(before));
    }

    function idListAddsOnlyCurrentUser(after, before) {
      return listOrEmpty(after).hasAll(listOrEmpty(before))
        && listOrEmpty(after).hasOnly(listOrEmpty(before).concat([request.auth.uid]));
    }

    function emailListAddsOnlyCurrentUser(after, before) {
      return listOrEmpty(after).hasAll(listOrEmpty(before))
        && listOrEmpty(after).hasOnly(listOrEmpty(before).concat([userEmail()]));
    }

    function emailListRemovesOnlyCurrentUser(after, before) {
      return userEmail() in listOrEmpty(before)
        && !(userEmail() in listOrEmpty(after))
        && listOrEmpty(before).hasAll(listOrEmpty(after))
        && listOrEmpty(after).hasOnly(listOrEmpty(before))
        && listOrEmpty(after).size() == listOrEmpty(before).size() - 1;
    }

    function emailListRemovesCurrentUserOrPreserved(after, before) {
      return (
        userEmail() in listOrEmpty(before)
        && emailListRemovesOnlyCurrentUser(after, before)
      ) || (
        !(userEmail() in listOrEmpty(before))
        && listPreserved(after, before)
      );
    }

    function moduleReadArraysAllowed(dataAfter, dataBefore, moduleName, granted) {
      return granted
        ? (
          idListAddsOnlyCurrentUser(moduleReaderIds(dataAfter, moduleName), moduleReaderIds(dataBefore, moduleName))
          && emailListAddsOnlyCurrentUser(moduleReaderEmails(dataAfter, moduleName), moduleReaderEmails(dataBefore, moduleName))
        )
        : (
          listPreserved(moduleReaderIds(dataAfter, moduleName), moduleReaderIds(dataBefore, moduleName))
          && listPreserved(moduleReaderEmails(dataAfter, moduleName), moduleReaderEmails(dataBefore, moduleName))
        );
    }

    function moduleWriteArraysAllowed(dataAfter, dataBefore, moduleName, granted) {
      return granted
        ? (
          idListAddsOnlyCurrentUser(moduleWriterIds(dataAfter, moduleName), moduleWriterIds(dataBefore, moduleName))
          && emailListAddsOnlyCurrentUser(moduleWriterEmails(dataAfter, moduleName), moduleWriterEmails(dataBefore, moduleName))
        )
        : (
          listPreserved(moduleWriterIds(dataAfter, moduleName), moduleWriterIds(dataBefore, moduleName))
          && listPreserved(moduleWriterEmails(dataAfter, moduleName), moduleWriterEmails(dataBefore, moduleName))
        );
    }

    function familyInvitationModuleArraysAllowed(familyId, moduleName) {
      return moduleReadArraysAllowed(
          request.resource.data,
          resource.data,
          moduleName,
          currentUserFamilyInvitationModuleCanRead(familyId, moduleName)
        )
        && moduleWriteArraysAllowed(
          request.resource.data,
          resource.data,
          moduleName,
          currentUserFamilyInvitationModuleCanWrite(familyId, moduleName)
        );
    }

    function familyInvitationAllModuleArraysAllowed(familyId) {
      return familyInvitationModuleArraysAllowed(familyId, "home")
        && familyInvitationModuleArraysAllowed(familyId, "calendar")
        && familyInvitationModuleArraysAllowed(familyId, "tasks")
        && familyInvitationModuleArraysAllowed(familyId, "meals")
        && familyInvitationModuleArraysAllowed(familyId, "lists")
        && familyInvitationModuleArraysAllowed(familyId, "groceries")
        && familyInvitationModuleArraysAllowed(familyId, "custody")
        && familyInvitationModuleArraysAllowed(familyId, "budget")
        && familyInvitationModuleArraysAllowed(familyId, "notifications");
    }

    function custodyInvitationModuleArraysAllowed(groupId, moduleName) {
      return moduleReadArraysAllowed(
          request.resource.data,
          resource.data,
          moduleName,
          currentUserCustodyInvitationModuleCanRead(groupId, moduleName)
        )
        && moduleWriteArraysAllowed(
          request.resource.data,
          resource.data,
          moduleName,
          currentUserCustodyInvitationModuleCanWrite(groupId, moduleName)
        );
    }

    function custodyInvitationAllModuleArraysAllowed(groupId) {
      return custodyInvitationModuleArraysAllowed(groupId, "custody")
        && custodyInvitationModuleArraysAllowed(groupId, "budget");
    }

    function currentUserCustodyInvitationAfterStatus(groupId, status) {
      return signedIn()
        && exists(currentUserCustodyInvitationPath(groupId))
        && getAfter(currentUserCustodyInvitationPath(groupId)).data.status == status
        && getAfter(currentUserCustodyInvitationPath(groupId)).data.recipientEmail == userEmail()
        && getAfter(currentUserCustodyInvitationPath(groupId)).data.groupId == groupId;
    }

    function familyMemberEmailsPreserved() {
      return listOrEmpty(request.resource.data.memberEmails)
        .hasAll(listOrEmpty(resource.data.memberEmails));
    }

    function familyMemberIdsPreserved() {
      return listOrEmpty(request.resource.data.memberIds)
        .hasAll(listOrEmpty(resource.data.memberIds));
    }

    function familyAdminEmailsPreserved() {
      return listOrEmpty(request.resource.data.adminEmails)
        .hasAll(listOrEmpty(resource.data.adminEmails));
    }

    function familyAdminIdsPreserved() {
      return listOrEmpty(request.resource.data.adminIds)
        .hasAll(listOrEmpty(resource.data.adminIds));
    }

    function canAcceptFamilyInvitationUpdate(familyId) {
      return signedIn()
        && familyExists(familyId)
        && userEmail() in listOrEmpty(resource.data.pendingMemberEmails)
        && request.auth.uid in listOrEmpty(request.resource.data.memberIds)
        && userEmail() in listOrEmpty(request.resource.data.memberEmails)
        && emailListRemovesOnlyCurrentUser(request.resource.data.pendingMemberEmails, resource.data.pendingMemberEmails)
        && idListAddsOnlyCurrentUser(request.resource.data.memberIds, resource.data.memberIds)
        && emailListAddsOnlyCurrentUser(request.resource.data.memberEmails, resource.data.memberEmails)
        && currentUserFamilyInvitationAfterStatus(familyId, "accepted")
        && (
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              "memberIds",
              "memberEmails",
              "member_emails",
              "pendingMemberEmails",
              "pending_member_emails",
              "pendingInvites",
              "pending_invites",
              "members",
              "homeReaderIds",
              "homeWriterIds",
              "homeReaderEmails",
              "homeWriterEmails",
              "calendarReaderIds",
              "calendarWriterIds",
              "calendarReaderEmails",
              "calendarWriterEmails",
              "tasksReaderIds",
              "tasksWriterIds",
              "tasksReaderEmails",
              "tasksWriterEmails",
              "mealsReaderIds",
              "mealsWriterIds",
              "mealsReaderEmails",
              "mealsWriterEmails",
              "listsReaderIds",
              "listsWriterIds",
              "listsReaderEmails",
              "listsWriterEmails",
              "groceriesReaderIds",
              "groceriesWriterIds",
              "groceriesReaderEmails",
              "groceriesWriterEmails",
              "custodyReaderIds",
              "custodyWriterIds",
              "custodyReaderEmails",
              "custodyWriterEmails",
              "budgetReaderIds",
              "budgetWriterIds",
              "budgetReaderEmails",
              "budgetWriterEmails",
              "notificationsReaderIds",
              "notificationsWriterIds",
              "notificationsReaderEmails",
              "notificationsWriterEmails",
              "updatedAt"
            ])
            && familyInvitationAllModuleArraysAllowed(familyId)
          )
          || (
            currentUserFamilyInvitationAfterGrantsAdmin(familyId)
            && request.auth.uid in listOrEmpty(request.resource.data.adminIds)
            && userEmail() in listOrEmpty(request.resource.data.adminEmails)
            && idListAddsOnlyCurrentUser(request.resource.data.adminIds, resource.data.adminIds)
            && emailListAddsOnlyCurrentUser(request.resource.data.adminEmails, resource.data.adminEmails)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              "memberIds",
              "memberEmails",
              "member_emails",
              "pendingMemberEmails",
              "pending_member_emails",
              "pendingInvites",
              "pending_invites",
              "members",
              "adminIds",
              "admin_ids",
              "adminEmails",
              "admin_emails",
              "updatedAt"
            ])
          )
        );
    }

    function canDeclineFamilyInvitationUpdate(familyId) {
      return signedIn()
        && familyExists(familyId)
        && userEmail() in listOrEmpty(resource.data.pendingMemberEmails)
        && emailListRemovesOnlyCurrentUser(request.resource.data.pendingMemberEmails, resource.data.pendingMemberEmails)
        && currentUserFamilyInvitationAfterStatus(familyId, "declined")
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "pendingMemberEmails",
          "pending_member_emails",
          "pendingInvites",
          "pending_invites",
          "updatedAt"
        ]);
    }

    function custodyMemberEmailsPreserved() {
      return listOrEmpty(request.resource.data.memberEmails)
        .hasAll(listOrEmpty(resource.data.memberEmails));
    }

    function custodyMemberIdsPreserved() {
      return listOrEmpty(request.resource.data.memberIds)
        .hasAll(listOrEmpty(resource.data.memberIds));
    }

    function custodyViewerEmailsPreserved() {
      return listOrEmpty(request.resource.data.viewerEmails)
        .hasAll(listOrEmpty(resource.data.viewerEmails));
    }

    function custodyViewerIdsPreserved() {
      return listOrEmpty(request.resource.data.viewerIds)
        .hasAll(listOrEmpty(resource.data.viewerIds));
    }

    function canAcceptCustodyMemberInvitationUpdate(groupId) {
      return signedIn()
        && custodyGroupExists(groupId)
        && userEmail() in listOrEmpty(resource.data.pendingMemberEmails)
        && request.auth.uid in listOrEmpty(request.resource.data.memberIds)
        && userEmail() in listOrEmpty(request.resource.data.memberEmails)
        && emailListRemovesOnlyCurrentUser(request.resource.data.pendingMemberEmails, resource.data.pendingMemberEmails)
        && idListAddsOnlyCurrentUser(request.resource.data.memberIds, resource.data.memberIds)
        && emailListAddsOnlyCurrentUser(request.resource.data.memberEmails, resource.data.memberEmails)
        && currentUserCustodyInvitationAfterStatus(groupId, "accepted")
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "memberIds",
          "memberEmails",
          "member_emails",
          "pendingMemberEmails",
          "pending_member_emails",
          "pendingInvites",
          "pending_invites",
          "custodyReaderIds",
          "custodyWriterIds",
          "custodyReaderEmails",
          "custodyWriterEmails",
          "budgetReaderIds",
          "budgetWriterIds",
          "budgetReaderEmails",
          "budgetWriterEmails",
          "updatedAt"
        ])
        && custodyInvitationAllModuleArraysAllowed(groupId);
    }

    function canAcceptCustodyViewerInvitationUpdate(groupId) {
      return signedIn()
        && custodyGroupExists(groupId)
        && userEmail() in listOrEmpty(resource.data.pendingViewerEmails)
        && request.auth.uid in listOrEmpty(request.resource.data.viewerIds)
        && userEmail() in listOrEmpty(request.resource.data.viewerEmails)
        && emailListRemovesOnlyCurrentUser(request.resource.data.pendingViewerEmails, resource.data.pendingViewerEmails)
        && idListAddsOnlyCurrentUser(request.resource.data.viewerIds, resource.data.viewerIds)
        && emailListAddsOnlyCurrentUser(request.resource.data.viewerEmails, resource.data.viewerEmails)
        && currentUserCustodyInvitationAfterStatus(groupId, "accepted")
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "viewerIds",
          "viewerEmails",
          "viewer_emails",
          "pendingViewerEmails",
          "pending_viewer_emails",
          "pendingInvites",
          "pending_invites",
          "custodyReaderIds",
          "custodyWriterIds",
          "custodyReaderEmails",
          "custodyWriterEmails",
          "budgetReaderIds",
          "budgetWriterIds",
          "budgetReaderEmails",
          "budgetWriterEmails",
          "updatedAt"
        ])
        && custodyInvitationAllModuleArraysAllowed(groupId);
    }

    function canDeclineCustodyInvitationUpdate(groupId) {
      return signedIn()
        && custodyGroupExists(groupId)
        && (
          userEmail() in listOrEmpty(resource.data.pendingMemberEmails)
          || userEmail() in listOrEmpty(resource.data.pendingViewerEmails)
        )
        && emailListRemovesCurrentUserOrPreserved(request.resource.data.pendingMemberEmails, resource.data.pendingMemberEmails)
        && emailListRemovesCurrentUserOrPreserved(request.resource.data.pendingViewerEmails, resource.data.pendingViewerEmails)
        && currentUserCustodyInvitationAfterStatus(groupId, "declined")
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "pendingMemberEmails",
          "pending_member_emails",
          "pendingViewerEmails",
          "pending_viewer_emails",
          "pendingInvites",
          "pending_invites",
          "updatedAt"
        ]);
    }

    function canRecipientUpdateFamilyInvitation() {
      return signedIn()
        && hasExistingFamilyId()
        && hasRequestFamilyId()
        && requestFamilyId() == existingFamilyId()
        && resource.data.recipientEmail == userEmail()
        && request.resource.data.recipientEmail == resource.data.recipientEmail
        && request.resource.data.status in ["accepted", "declined"]
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "acceptedBy",
          "accepted_by",
          "acceptedAt",
          "accepted_at",
          "declinedBy",
          "declined_by",
          "declinedAt",
          "declined_at",
          "updatedAt",
          "updated_at"
        ]);
    }

    function canRecipientUpdateCustodyInvitation() {
      return signedIn()
        && hasExistingFamilyId()
        && hasRequestFamilyId()
        && requestFamilyId() == existingFamilyId()
        && resource.data.recipientEmail == userEmail()
        && request.resource.data.recipientEmail == resource.data.recipientEmail
        && request.resource.data.groupId == resource.data.groupId
        && request.resource.data.status in ["accepted", "declined"]
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "acceptedBy",
          "accepted_by",
          "acceptedAt",
          "accepted_at",
          "declinedBy",
          "declined_by",
          "declinedAt",
          "declined_at",
          "updatedAt",
          "updated_at"
        ]);
    }

    function validMailMessage() {
      return request.resource.data.message is map
        && request.resource.data.message.subject is string
        && request.resource.data.message.text is string
        && request.resource.data.message.html is string;
    }

    function validMailRecipient() {
      return request.resource.data.recipientEmail is string
        && request.resource.data.to is list
        && request.resource.data.to.size() == 1
        && request.resource.data.to[0] == request.resource.data.recipientEmail;
    }

    function canCreateFamilyInvitationMail() {
      return request.resource.data.kind == "family_invitation"
        && request.resource.data.familyId is string
        && request.resource.data.invitationCollection == "familyInvitations"
        && canManageFamily(request.resource.data.familyId);
    }

    function canCreateCustodyInvitationMail() {
      return request.resource.data.kind == "custody_invitation"
        && request.resource.data.custodyGroupId is string
        && request.resource.data.invitationCollection == "custodyInvitations"
        && canManageCustodyGroup(request.resource.data.custodyGroupId);
    }

    function canCreateNotificationMail() {
      return request.resource.data.kind == "notification"
        && (
          (
            request.resource.data.familyId is string
            && canWriteFamilyModule(request.resource.data.familyId, "notifications")
          )
          || (
            request.resource.data.custodyGroupId is string
            && canWriteCustody(request.resource.data.custodyGroupId)
          )
        );
    }

    function canCreateMailDoc() {
      return signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == "queued"
        && validMailRecipient()
        && validMailMessage()
        && (
          canCreateFamilyInvitationMail()
          || canCreateCustodyInvitationMail()
          || canCreateNotificationMail()
        );
    }

    function isNotificationRecipient(data) {
      return signedIn()
        && (
          data.recipientUid == request.auth.uid
          || data.recipient_uid == request.auth.uid
          || data.recipientEmail == userEmail()
          || data.recipient_email == userEmail()
        );
    }

    function canCreateFamilyNotification() {
      return request.resource.data.familyId is string
        && request.resource.data.familyId != ""
        && (
          canManageFamily(request.resource.data.familyId)
          || canWriteFamilyModule(request.resource.data.familyId, "notifications")
        );
    }

    function canCreateCustodyNotification() {
      return request.resource.data.custodyGroupId is string
        && request.resource.data.custodyGroupId != ""
        && (
          canManageCustodyGroup(request.resource.data.custodyGroupId)
          || canWriteCustody(request.resource.data.custodyGroupId)
        );
    }

    function canCreateNotificationDoc() {
      return signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.recipientEmail is string
        && request.resource.data.title is string
        && request.resource.data.kind is string
        && request.resource.data.status == "unread"
        && (
          canCreateFamilyNotification()
          || canCreateCustodyNotification()
        );
    }

    function canReadNotificationDoc() {
      return isNotificationRecipient(resource.data)
        || (
          hasExistingFamilyId()
          && canManageFamily(existingFamilyId())
        )
        || (
          hasExistingCustodyScopeId()
          && canManageCustodyGroup(existingCustodyScopeId())
        );
    }

    function canUpdateOwnNotification() {
      return isNotificationRecipient(resource.data)
        && request.resource.data.recipientEmail == resource.data.recipientEmail
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "read",
          "readAt",
          "read_by",
          "readBy",
          "updatedAt"
        ])
        && request.resource.data.status in ["read", "unread"];
    }

    match /users/{userId} {
      allow read, create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /families/{familyId} {
      allow read: if canReadFamily(familyId)
        || canReadBootstrapFamily(familyId);
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if canManageFamily(familyId)
        || canAcceptFamilyInvitationUpdate(familyId)
        || canDeclineFamilyInvitationUpdate(familyId);
      allow delete: if canManageFamily(familyId);
    }

    match /custodyGroups/{groupId} {
      allow read: if canReadCustody(groupId);
      allow create: if signedIn()
        && hasRequestFamilyId()
        && canManageFamily(requestFamilyId())
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if canWriteCustody(groupId)
        || canAcceptCustodyMemberInvitationUpdate(groupId)
        || canAcceptCustodyViewerInvitationUpdate(groupId)
        || canDeclineCustodyInvitationUpdate(groupId);
      allow delete: if canManageCustodyGroup(groupId);
    }

    match /familyEvents/{docId} {
      allow read: if canReadHouseholdModuleDoc("calendar");
      allow create: if canCreateHouseholdModuleDoc("calendar");
      allow update: if canUpdateHouseholdModuleDoc("calendar");
      allow delete: if canDeleteHouseholdModuleDoc("calendar");
    }

    match /tasks/{docId} {
      allow read: if canReadHouseholdModuleDoc("tasks");
      allow create: if canCreateHouseholdModuleDoc("tasks");
      allow update: if canUpdateHouseholdModuleDoc("tasks");
      allow delete: if canDeleteHouseholdModuleDoc("tasks");
    }

    match /taskTemplates/{docId} {
      allow read: if canReadHouseholdModuleDoc("tasks");
      allow create: if canCreateHouseholdModuleDoc("tasks");
      allow update: if canUpdateHouseholdModuleDoc("tasks");
      allow delete: if canDeleteHouseholdModuleDoc("tasks");
    }

    match /routineRuns/{docId} {
      allow read: if canReadHouseholdModuleDoc("tasks");
      allow create: if canCreateHouseholdModuleDoc("tasks");
      allow update: if canUpdateHouseholdModuleDoc("tasks");
      allow delete: if canDeleteHouseholdModuleDoc("tasks");
    }

    match /rewards/{docId} {
      allow read: if canReadHouseholdModuleDoc("tasks");
      allow create: if canCreateHouseholdModuleDoc("tasks");
      allow update: if canUpdateHouseholdModuleDoc("tasks");
      allow delete: if canDeleteHouseholdModuleDoc("tasks");
    }

    match /meals/{docId} {
      allow read: if canReadHouseholdModuleDoc("meals");
      allow create: if canCreateHouseholdModuleDoc("meals");
      allow update: if canUpdateHouseholdModuleDoc("meals");
      allow delete: if canDeleteHouseholdModuleDoc("meals");
    }

    match /mealTemplates/{docId} {
      allow read: if canReadHouseholdModuleDoc("meals");
      allow create: if canCreateHouseholdModuleDoc("meals");
      allow update: if canUpdateHouseholdModuleDoc("meals");
      allow delete: if canDeleteHouseholdModuleDoc("meals");
    }

    match /familyLists/{docId} {
      allow read: if canReadHouseholdModuleDoc("lists");
      allow create: if canCreateHouseholdModuleDoc("lists");
      allow update: if canUpdateHouseholdModuleDoc("lists");
      allow delete: if canDeleteHouseholdModuleDoc("lists");
    }

    match /familyListItems/{docId} {
      allow read: if canReadHouseholdModuleDoc("lists");
      allow create: if canCreateHouseholdModuleDoc("lists");
      allow update: if canUpdateHouseholdModuleDoc("lists");
      allow delete: if canDeleteHouseholdModuleDoc("lists");
    }

    match /familyPantryItems/{docId} {
      allow read: if canReadHouseholdModuleDoc("lists");
      allow create: if canCreateHouseholdModuleDoc("lists");
      allow update: if canUpdateHouseholdModuleDoc("lists");
      allow delete: if canDeleteHouseholdModuleDoc("lists");
    }

    match /children/{docId} {
      allow read: if canReadHouseholdModuleDoc("home");
      allow create: if hasRequestFamilyId() && canManageFamily(requestFamilyId());
      allow update: if hasRequestFamilyId()
        && hasExistingFamilyId()
        && requestFamilyId() == existingFamilyId()
        && canManageFamily(existingFamilyId());
      allow delete: if hasExistingFamilyId() && canManageFamily(existingFamilyId());
    }

    match /familyMembers/{docId} {
      allow read: if canReadHouseholdDoc();
      allow create: if hasRequestFamilyId() && canManageFamily(requestFamilyId());
      allow update: if hasRequestFamilyId()
        && hasExistingFamilyId()
        && requestFamilyId() == existingFamilyId()
        && canManageFamily(existingFamilyId());
      allow delete: if hasExistingFamilyId() && canManageFamily(existingFamilyId());
    }

    match /familyActivity/{docId} {
      allow read: if canReadAnyScopedDoc();
      allow create: if canCreateAnyScopedDoc()
        && (
          request.resource.data.createdBy == request.auth.uid
          || request.resource.data.actorId == request.auth.uid
        );
      allow update: if false;
      allow delete: if canDeleteAnyScopedDoc();
    }

    match /familyInvitations/{docId} {
      allow read: if canReadHouseholdDoc()
        || (signedIn() && resource.data.recipientEmail == userEmail());
      allow create: if hasRequestFamilyId()
        && canManageFamily(requestFamilyId())
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if (
          hasRequestFamilyId()
          && hasExistingFamilyId()
          && requestFamilyId() == existingFamilyId()
          && canManageFamily(existingFamilyId())
        )
        || canRecipientUpdateFamilyInvitation();
      allow delete: if hasExistingFamilyId() && canManageFamily(existingFamilyId());
    }

    match /custodyInvitations/{docId} {
      allow read: if canReadCustodyDoc()
        || (signedIn() && resource.data.recipientEmail == userEmail());
      allow create: if canCreateCustodyDoc()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if canUpdateCustodyDoc()
        || canRecipientUpdateCustodyInvitation();
      allow delete: if canDeleteCustodyDoc();
    }

    match /mail/{mailId} {
      allow create: if canCreateMailDoc();
      allow read, update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if canReadNotificationDoc();
      allow create: if canCreateNotificationDoc();
      allow update: if canUpdateOwnNotification();
      allow delete: if (
          hasExistingFamilyId()
          && canManageFamily(existingFamilyId())
        )
        || (
          hasExistingCustodyScopeId()
          && canManageCustodyGroup(existingCustodyScopeId())
        );
    }

    match /custodyDays/{docId} {
      allow read: if canReadCustodyDoc();
      allow create: if canCreateCustodyDoc();
      allow update: if canUpdateCustodyDoc();
      allow delete: if canDeleteCustodyDoc();
    }

    match /custodySpecialEvents/{docId} {
      allow read: if canReadCustodyDoc();
      allow create: if canCreateCustodyDoc();
      allow update: if canUpdateCustodyDoc();
      allow delete: if canDeleteCustodyDoc();
    }

    match /custodyTravelPlans/{docId} {
      allow read: if canReadCustodyDoc();
      allow create: if canCreateCustodyDoc();
      allow update: if canUpdateCustodyDoc();
      allow delete: if canDeleteCustodyDoc();
    }

    match /custodyExchanges/{docId} {
      allow read: if canReadCustodyDoc();
      allow create: if canCreateCustodyDoc();
      allow update: if canUpdateCustodyDoc();
      allow delete: if canDeleteCustodyDoc();
    }

    match /custodyPackingItems/{docId} {
      allow read: if canReadCustodyDoc();
      allow create: if canCreateCustodyDoc();
      allow update: if canUpdateCustodyDoc();
      allow delete: if canDeleteCustodyDoc();
    }

    match /custodyExpenses/{docId} {
      allow read: if canReadBudgetDoc();
      allow create: if canCreateBudgetDoc();
      allow update: if canUpdateBudgetDoc();
      allow delete: if canDeleteBudgetDoc();
    }

    match /custodyNotificationPrefs/{scopeId} {
      allow read: if canReadCustody(scopeId) || canReadCustodyDoc();
      allow create: if canCreateCustodyDoc()
        && requestCustodyScopeId() == scopeId;
      allow update: if canUpdateCustodyDoc()
        && requestCustodyScopeId() == scopeId;
      allow delete: if canManageCustodyGroup(scopeId) || canDeleteCustodyDoc();
    }

    match /groceries/{docId} {
      allow read: if canReadHouseholdModuleDoc("lists");
      allow create: if canCreateHouseholdModuleDoc("lists");
      allow update: if canUpdateHouseholdModuleDoc("lists");
      allow delete: if canDeleteHouseholdModuleDoc("lists");
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
