rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return signedIn() && request.auth.token.email != null
        ? request.auth.token.email.lower()
        : "";
    }

    function listOrEmpty(value) {
      return value is list ? value : [];
    }

    function cleanString(value) {
      return value is string ? value : "";
    }

    function familyPath(familyId) {
      return /databases/$(database)/documents/families/$(familyId);
    }

    function custodyPath(groupId) {
      return /databases/$(database)/documents/custodyGroups/$(groupId);
    }

    function familyData(familyId) {
      return get(familyPath(familyId)).data;
    }

    function custodyData(groupId) {
      return get(custodyPath(groupId)).data;
    }

    function hasRequestFamilyId() {
      return cleanString(request.resource.data.get("familyId", "")) != ""
        || cleanString(request.resource.data.get("family_id", "")) != "";
    }

    function hasExistingFamilyId() {
      return cleanString(resource.data.get("familyId", "")) != ""
        || cleanString(resource.data.get("family_id", "")) != "";
    }

    function requestFamilyId() {
      return cleanString(request.resource.data.get("familyId", "")) != ""
        ? cleanString(request.resource.data.get("familyId", ""))
        : cleanString(request.resource.data.get("family_id", ""));
    }

    function existingFamilyId() {
      return cleanString(resource.data.get("familyId", "")) != ""
        ? cleanString(resource.data.get("familyId", ""))
        : cleanString(resource.data.get("family_id", ""));
    }

    function requestCustodyGroupId() {
      return cleanString(request.resource.data.get("custodyGroupId", "")) != ""
        ? cleanString(request.resource.data.get("custodyGroupId", ""))
        : cleanString(request.resource.data.get("custody_group_id", "")) != ""
        ? cleanString(request.resource.data.get("custody_group_id", ""))
        : cleanString(request.resource.data.get("familyId", ""));
    }

    function existingCustodyGroupId() {
      return cleanString(resource.data.get("custodyGroupId", "")) != ""
        ? cleanString(resource.data.get("custodyGroupId", ""))
        : cleanString(resource.data.get("custody_group_id", "")) != ""
        ? cleanString(resource.data.get("custody_group_id", ""))
        : cleanString(resource.data.get("familyId", ""));
    }

    function hasRequestCustodyGroupId() {
      return requestCustodyGroupId() != "";
    }

    function hasExistingCustodyGroupId() {
      return existingCustodyGroupId() != "";
    }

    function hasExplicitRequestCustodyGroupId() {
      return cleanString(request.resource.data.get("custodyGroupId", "")) != ""
        || cleanString(request.resource.data.get("custody_group_id", "")) != "";
    }

    function hasExplicitExistingCustodyGroupId() {
      return cleanString(resource.data.get("custodyGroupId", "")) != ""
        || cleanString(resource.data.get("custody_group_id", "")) != "";
    }

    function isFamilyOwnerData(data) {
      return signedIn()
        && (
          request.auth.uid == cleanString(data.get("ownerId", ""))
          || request.auth.uid == cleanString(data.get("owner_id", ""))
          || request.auth.uid == cleanString(data.get("createdBy", ""))
          || request.auth.uid == cleanString(data.get("created_by", ""))
          || userEmail() == cleanString(data.get("ownerEmail", ""))
          || userEmail() == cleanString(data.get("owner_email", ""))
          || userEmail() == cleanString(data.get("createdByEmail", ""))
          || userEmail() == cleanString(data.get("created_by_email", ""))
          || userEmail() == cleanString(data.get("created_by", ""))
        );
    }

    function isFamilyAdminData(data) {
      return isFamilyOwnerData(data)
        || request.auth.uid in listOrEmpty(data.get("adminIds", []))
        || request.auth.uid in listOrEmpty(data.get("admin_ids", []))
        || userEmail() in listOrEmpty(data.get("adminEmails", []))
        || userEmail() in listOrEmpty(data.get("admin_emails", []));
    }

    function isFamilyListedMemberData(data) {
      return request.auth.uid in listOrEmpty(data.get("memberIds", []))
        || request.auth.uid in listOrEmpty(data.get("member_ids", []))
        || userEmail() in listOrEmpty(data.get("memberEmails", []))
        || userEmail() in listOrEmpty(data.get("member_emails", []));
    }

    function isFamilyListedViewerData(data) {
      return request.auth.uid in listOrEmpty(data.get("viewerIds", []))
        || request.auth.uid in listOrEmpty(data.get("viewer_ids", []))
        || userEmail() in listOrEmpty(data.get("viewerEmails", []))
        || userEmail() in listOrEmpty(data.get("viewer_emails", []));
    }

    function isFamilyMemberData(data) {
      return isFamilyAdminData(data) || isFamilyListedMemberData(data);
    }

    function isFamilyViewerData(data) {
      return isFamilyMemberData(data) || isFamilyListedViewerData(data);
    }

    function isOwnFamilyMemberRecord(data) {
      return signedIn()
        && (
          request.auth.uid == cleanString(data.get("uid", ""))
          || request.auth.uid == cleanString(data.get("userId", ""))
          || request.auth.uid == cleanString(data.get("user_id", ""))
          || userEmail() == cleanString(data.get("email", "")).lower()
          || userEmail() == cleanString(data.get("memberEmail", "")).lower()
          || userEmail() == cleanString(data.get("member_email", "")).lower()
        );
    }

    function canReadFamily(familyId) {
      return signedIn()
        && exists(familyPath(familyId))
        && isFamilyViewerData(familyData(familyId));
    }

    function canManageFamily(familyId) {
      return signedIn()
        && exists(familyPath(familyId))
        && isFamilyAdminData(familyData(familyId));
    }

    function moduleHasPolicy(data, moduleName) {
      return (moduleName == "home" && data.keys().hasAny(["homeReaderIds", "homeWriterIds", "homeReaderEmails", "homeWriterEmails", "home_reader_ids", "home_writer_ids", "home_reader_emails", "home_writer_emails"]))
        || (moduleName == "calendar" && data.keys().hasAny(["calendarReaderIds", "calendarWriterIds", "calendarReaderEmails", "calendarWriterEmails", "calendar_reader_ids", "calendar_writer_ids", "calendar_reader_emails", "calendar_writer_emails"]))
        || (moduleName == "tasks" && data.keys().hasAny(["tasksReaderIds", "tasksWriterIds", "tasksReaderEmails", "tasksWriterEmails", "tasks_reader_ids", "tasks_writer_ids", "tasks_reader_emails", "tasks_writer_emails"]))
        || (moduleName == "meals" && data.keys().hasAny(["mealsReaderIds", "mealsWriterIds", "mealsReaderEmails", "mealsWriterEmails", "meals_reader_ids", "meals_writer_ids", "meals_reader_emails", "meals_writer_emails"]))
        || (moduleName == "lists" && data.keys().hasAny(["listsReaderIds", "listsWriterIds", "listsReaderEmails", "listsWriterEmails", "lists_reader_ids", "lists_writer_ids", "lists_reader_emails", "lists_writer_emails"]))
        || (moduleName == "custody" && data.keys().hasAny(["custodyReaderIds", "custodyWriterIds", "custodyReaderEmails", "custodyWriterEmails", "custody_reader_ids", "custody_writer_ids", "custody_reader_emails", "custody_writer_emails"]))
        || (moduleName == "budget" && data.keys().hasAny(["budgetReaderIds", "budgetWriterIds", "budgetReaderEmails", "budgetWriterEmails", "budget_reader_ids", "budget_writer_ids", "budget_reader_emails", "budget_writer_emails"]))
        || (moduleName == "notifications" && data.keys().hasAny(["notificationsReaderIds", "notificationsWriterIds", "notificationsReaderEmails", "notificationsWriterEmails", "notifications_reader_ids", "notifications_writer_ids", "notifications_reader_emails", "notifications_writer_emails"]));
    }

    function moduleReadGrant(data, moduleName) {
      return (moduleName == "home" && (
          request.auth.uid in listOrEmpty(data.get("homeReaderIds", []))
          || request.auth.uid in listOrEmpty(data.get("homeWriterIds", []))
          || request.auth.uid in listOrEmpty(data.get("home_reader_ids", []))
          || request.auth.uid in listOrEmpty(data.get("home_writer_ids", []))
          || userEmail() in listOrEmpty(data.get("homeReaderEmails", []))
          || userEmail() in listOrEmpty(data.get("homeWriterEmails", []))
          || userEmail() in listOrEmpty(data.get("home_reader_emails", []))
          || userEmail() in listOrEmpty(data.get("home_writer_emails", []))
        ))
        || (moduleName == "calendar" && (
          request.auth.uid in listOrEmpty(data.get("calendarReaderIds", []))
          || request.auth.uid in listOrEmpty(data.get("calendarWriterIds", []))
          || userEmail() in listOrEmpty(data.get("calendarReaderEmails", []))
          || userEmail() in listOrEmpty(data.get("calendarWriterEmails", []))
        ))
        || (moduleName == "tasks" && (
          request.auth.uid in listOrEmpty(data.get("tasksReaderIds", []))
          || request.auth.uid in listOrEmpty(data.get("tasksWriterIds", []))
          || userEmail() in listOrEmpty(data.get("tasksReaderEmails", []))
          || userEmail() in listOrEmpty(data.get("tasksWriterEmails", []))
        ))
        || (moduleName == "meals" && (
          request.auth.uid in listOrEmpty(data.get("mealsReaderIds", []))
          || request.auth.uid in listOrEmpty(data.get("mealsWriterIds", []))
          || userEmail() in listOrEmpty(data.get("mealsReaderEmails", []))
          || userEmail() in listOrEmpty(data.get("mealsWriterEmails", []))
        ))
        || (moduleName == "lists" && (
          request.auth.uid in listOrEmpty(data.get("listsReaderIds", []))
          || request.auth.uid in listOrEmpty(data.get("listsWriterIds", []))
          || userEmail() in listOrEmpty(data.get("listsReaderEmails", []))
          || userEmail() in listOrEmpty(data.get("listsWriterEmails", []))
        ))
        || (moduleName == "custody" && (
          request.auth.uid in listOrEmpty(data.get("custodyReaderIds", []))
          || request.auth.uid in listOrEmpty(data.get("custodyWriterIds", []))
          || userEmail() in listOrEmpty(data.get("custodyReaderEmails", []))
          || userEmail() in listOrEmpty(data.get("custodyWriterEmails", []))
        ))
        || (moduleName == "budget" && (
          request.auth.uid in listOrEmpty(data.get("budgetReaderIds", []))
          || request.auth.uid in listOrEmpty(data.get("budgetWriterIds", []))
          || userEmail() in listOrEmpty(data.get("budgetReaderEmails", []))
          || userEmail() in listOrEmpty(data.get("budgetWriterEmails", []))
        ))
        || (moduleName == "notifications" && (
          request.auth.uid in listOrEmpty(data.get("notificationsReaderIds", []))
          || request.auth.uid in listOrEmpty(data.get("notificationsWriterIds", []))
          || userEmail() in listOrEmpty(data.get("notificationsReaderEmails", []))
          || userEmail() in listOrEmpty(data.get("notificationsWriterEmails", []))
        ));
    }

    function moduleWriteGrant(data, moduleName) {
      return (moduleName == "home" && (
          request.auth.uid in listOrEmpty(data.get("homeWriterIds", []))
          || userEmail() in listOrEmpty(data.get("homeWriterEmails", []))
        ))
        || (moduleName == "calendar" && (
          request.auth.uid in listOrEmpty(data.get("calendarWriterIds", []))
          || userEmail() in listOrEmpty(data.get("calendarWriterEmails", []))
        ))
        || (moduleName == "tasks" && (
          request.auth.uid in listOrEmpty(data.get("tasksWriterIds", []))
          || userEmail() in listOrEmpty(data.get("tasksWriterEmails", []))
        ))
        || (moduleName == "meals" && (
          request.auth.uid in listOrEmpty(data.get("mealsWriterIds", []))
          || userEmail() in listOrEmpty(data.get("mealsWriterEmails", []))
        ))
        || (moduleName == "lists" && (
          request.auth.uid in listOrEmpty(data.get("listsWriterIds", []))
          || userEmail() in listOrEmpty(data.get("listsWriterEmails", []))
        ))
        || (moduleName == "custody" && (
          request.auth.uid in listOrEmpty(data.get("custodyWriterIds", []))
          || userEmail() in listOrEmpty(data.get("custodyWriterEmails", []))
        ))
        || (moduleName == "budget" && (
          request.auth.uid in listOrEmpty(data.get("budgetWriterIds", []))
          || userEmail() in listOrEmpty(data.get("budgetWriterEmails", []))
        ))
        || (moduleName == "notifications" && (
          request.auth.uid in listOrEmpty(data.get("notificationsWriterIds", []))
          || userEmail() in listOrEmpty(data.get("notificationsWriterEmails", []))
        ));
    }

    function canReadFamilyModule(familyId, moduleName) {
      return signedIn()
        && exists(familyPath(familyId))
        && (
          isFamilyAdminData(familyData(familyId))
          || moduleReadGrant(familyData(familyId), moduleName)
          || (
            isFamilyListedMemberData(familyData(familyId))
            && !moduleHasPolicy(familyData(familyId), moduleName)
          )
        );
    }

    function canWriteFamilyModule(familyId, moduleName) {
      return signedIn()
        && exists(familyPath(familyId))
        && (
          isFamilyAdminData(familyData(familyId))
          || moduleWriteGrant(familyData(familyId), moduleName)
          || (
            isFamilyListedMemberData(familyData(familyId))
            && !moduleHasPolicy(familyData(familyId), moduleName)
          )
        );
    }

    function custodyHouseholdFamilyId(data) {
      return cleanString(data.get("householdFamilyId", "")) != ""
        ? cleanString(data.get("householdFamilyId", ""))
        : cleanString(data.get("familyId", ""));
    }

    function isCustodyOwnerData(data) {
      return signedIn()
        && (
          request.auth.uid == cleanString(data.get("ownerId", ""))
          || request.auth.uid == cleanString(data.get("createdBy", ""))
          || userEmail() == cleanString(data.get("ownerEmail", ""))
          || userEmail() == cleanString(data.get("createdByEmail", ""))
        );
    }

    function isCustodyAdminData(data) {
      return isCustodyOwnerData(data)
        || request.auth.uid in listOrEmpty(data.get("adminIds", []))
        || userEmail() in listOrEmpty(data.get("adminEmails", []));
    }

    function isCustodyMemberData(data) {
      return isCustodyAdminData(data)
        || request.auth.uid in listOrEmpty(data.get("memberIds", []))
        || userEmail() in listOrEmpty(data.get("memberEmails", []));
    }

    function isCustodyViewerData(data) {
      return isCustodyMemberData(data)
        || request.auth.uid in listOrEmpty(data.get("viewerIds", []))
        || userEmail() in listOrEmpty(data.get("viewerEmails", []))
        || request.auth.uid in listOrEmpty(data.get("custodyReaderIds", []))
        || userEmail() in listOrEmpty(data.get("custodyReaderEmails", []));
    }

    function canReadCustody(groupId) {
      return signedIn()
        && exists(custodyPath(groupId))
        && (
          isCustodyViewerData(custodyData(groupId))
          || canManageFamily(custodyHouseholdFamilyId(custodyData(groupId)))
          || canReadFamilyModule(custodyHouseholdFamilyId(custodyData(groupId)), "custody")
        );
    }

    function canWriteCustody(groupId) {
      return signedIn()
        && exists(custodyPath(groupId))
        && (
          isCustodyAdminData(custodyData(groupId))
          || request.auth.uid in listOrEmpty(custodyData(groupId).get("custodyWriterIds", []))
          || userEmail() in listOrEmpty(custodyData(groupId).get("custodyWriterEmails", []))
          || canManageFamily(custodyHouseholdFamilyId(custodyData(groupId)))
          || canWriteFamilyModule(custodyHouseholdFamilyId(custodyData(groupId)), "custody")
        );
    }

    function canManageCustody(groupId) {
      return signedIn()
        && exists(custodyPath(groupId))
        && (
          isCustodyAdminData(custodyData(groupId))
          || canManageFamily(custodyHouseholdFamilyId(custodyData(groupId)))
        );
    }

    function canReadBudget(groupId) {
      return signedIn()
        && exists(custodyPath(groupId))
        && (
          canManageCustody(groupId)
          || request.auth.uid in listOrEmpty(custodyData(groupId).get("budgetReaderIds", []))
          || request.auth.uid in listOrEmpty(custodyData(groupId).get("budgetWriterIds", []))
          || userEmail() in listOrEmpty(custodyData(groupId).get("budgetReaderEmails", []))
          || userEmail() in listOrEmpty(custodyData(groupId).get("budgetWriterEmails", []))
        );
    }

    function canWriteBudget(groupId) {
      return signedIn()
        && exists(custodyPath(groupId))
        && (
          canManageCustody(groupId)
          || request.auth.uid in listOrEmpty(custodyData(groupId).get("budgetWriterIds", []))
          || userEmail() in listOrEmpty(custodyData(groupId).get("budgetWriterEmails", []))
        );
    }

    function isNotificationRecipient(data) {
      return signedIn()
        && (
          cleanString(data.get("recipientUid", "")) == request.auth.uid
          || cleanString(data.get("recipient_uid", "")) == request.auth.uid
          || cleanString(data.get("recipientEmail", "")).lower() == userEmail()
          || cleanString(data.get("recipient_email", "")).lower() == userEmail()
        );
    }

    function canReadHouseholdDoc() {
      return hasExistingFamilyId() && canReadFamily(existingFamilyId());
    }

    function canReadHouseholdModuleDoc(moduleName) {
      return hasExistingFamilyId() && canReadFamilyModule(existingFamilyId(), moduleName);
    }

    function canCreateHouseholdModuleDoc(moduleName) {
      return hasRequestFamilyId() && canWriteFamilyModule(requestFamilyId(), moduleName);
    }

    function canUpdateHouseholdModuleDoc(moduleName) {
      return hasRequestFamilyId()
        && hasExistingFamilyId()
        && requestFamilyId() == existingFamilyId()
        && canWriteFamilyModule(existingFamilyId(), moduleName);
    }

    function canDeleteHouseholdModuleDoc(moduleName) {
      return hasExistingFamilyId() && canWriteFamilyModule(existingFamilyId(), moduleName);
    }

    function canReadCustodyDoc() {
      return (
          hasExistingCustodyGroupId()
          && canReadCustody(existingCustodyGroupId())
        )
        || (
          hasExistingFamilyId()
          && canReadFamilyModule(existingFamilyId(), "custody")
        );
    }

    function canCreateCustodyDoc() {
      return hasRequestCustodyGroupId() && canWriteCustody(requestCustodyGroupId());
    }

    function canUpdateCustodyDoc() {
      return hasRequestCustodyGroupId()
        && hasExistingCustodyGroupId()
        && requestCustodyGroupId() == existingCustodyGroupId()
        && canWriteCustody(existingCustodyGroupId());
    }

    function canDeleteCustodyDoc() {
      return hasExistingCustodyGroupId() && canWriteCustody(existingCustodyGroupId());
    }

    function canReadAnyScopedDoc() {
      return (
          hasExplicitExistingCustodyGroupId()
          && canReadCustody(existingCustodyGroupId())
        )
        || (
          !hasExplicitExistingCustodyGroupId()
          && hasExistingFamilyId()
          && canReadFamilyModule(existingFamilyId(), "home")
        );
    }

    function canCreateActivityDoc() {
      return signedIn()
        && (
          request.resource.data.get("createdBy", "") == request.auth.uid
          || request.resource.data.get("actorId", "") == request.auth.uid
        )
        && (
          (
            hasExplicitRequestCustodyGroupId()
            && canWriteCustody(requestCustodyGroupId())
          )
          || (
            !hasExplicitRequestCustodyGroupId()
            && hasRequestFamilyId()
            && canWriteFamilyModule(requestFamilyId(), cleanString(request.resource.data.get("module", "home")))
          )
        );
    }

    function canReadNotificationDoc() {
      return isNotificationRecipient(resource.data)
        || (
          hasExistingFamilyId()
          && canManageFamily(existingFamilyId())
        )
        || (
          hasExistingCustodyGroupId()
          && canManageCustody(existingCustodyGroupId())
        );
    }

    function canCreateNotificationDoc() {
      return signedIn()
        && request.resource.data.get("createdBy", "") == request.auth.uid
        && cleanString(request.resource.data.get("recipientEmail", "")) != ""
        && cleanString(request.resource.data.get("title", "")) != ""
        && cleanString(request.resource.data.get("kind", "")) != ""
        && request.resource.data.get("status", "") == "unread"
        && (
          (
            cleanString(request.resource.data.get("familyId", "")) != ""
            && (
              canManageFamily(cleanString(request.resource.data.get("familyId", "")))
              || canWriteFamilyModule(cleanString(request.resource.data.get("familyId", "")), "notifications")
              || (
                isNotificationRecipient(request.resource.data)
                && canReadFamily(cleanString(request.resource.data.get("familyId", "")))
              )
            )
          )
          || (
            cleanString(request.resource.data.get("custodyGroupId", "")) != ""
            && (
              canManageCustody(cleanString(request.resource.data.get("custodyGroupId", "")))
              || canWriteCustody(cleanString(request.resource.data.get("custodyGroupId", "")))
              || (
                isNotificationRecipient(request.resource.data)
                && canReadCustody(cleanString(request.resource.data.get("custodyGroupId", "")))
              )
            )
          )
        );
    }

    function canUpdateOwnNotification() {
      return isNotificationRecipient(resource.data)
        && request.resource.data.get("recipientEmail", "") == resource.data.get("recipientEmail", "")
        && request.resource.data.get("createdBy", "") == resource.data.get("createdBy", "")
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "read",
          "readAt",
          "read_by",
          "readBy",
          "updatedAt"
        ])
        && request.resource.data.get("status", "") in ["read", "unread"];
    }

    match /users/{userId} {
      allow read, create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /families/{familyId} {
      allow read: if (signedIn() && isFamilyViewerData(resource.data))
        || (signedIn() && familyId == "family_" + request.auth.uid);
      allow create: if signedIn() && request.resource.data.get("ownerId", "") == request.auth.uid;
      allow update, delete: if canManageFamily(familyId);
    }

    match /familyEvents/{docId} {
      allow read: if canReadHouseholdModuleDoc("calendar");
      allow create: if canCreateHouseholdModuleDoc("calendar");
      allow update: if canUpdateHouseholdModuleDoc("calendar");
      allow delete: if canDeleteHouseholdModuleDoc("calendar");
    }

    match /tasks/{docId} {
      allow read: if canReadHouseholdModuleDoc("tasks");
      allow create: if canCreateHouseholdModuleDoc("tasks");
      allow update: if canUpdateHouseholdModuleDoc("tasks");
      allow delete: if canDeleteHouseholdModuleDoc("tasks");
    }

    match /taskTemplates/{docId} {
      allow read: if canReadHouseholdModuleDoc("tasks");
      allow create: if canCreateHouseholdModuleDoc("tasks");
      allow update: if canUpdateHouseholdModuleDoc("tasks");
      allow delete: if canDeleteHouseholdModuleDoc("tasks");
    }

    match /routineRuns/{docId} {
      allow read: if canReadHouseholdModuleDoc("tasks");
      allow create: if canCreateHouseholdModuleDoc("tasks");
      allow update: if canUpdateHouseholdModuleDoc("tasks");
      allow delete: if canDeleteHouseholdModuleDoc("tasks");
    }

    match /rewards/{docId} {
      allow read: if canReadHouseholdModuleDoc("tasks");
      allow create: if canCreateHouseholdModuleDoc("tasks");
      allow update: if canUpdateHouseholdModuleDoc("tasks");
      allow delete: if canDeleteHouseholdModuleDoc("tasks");
    }

    match /meals/{docId} {
      allow read: if canReadHouseholdModuleDoc("meals");
      allow create: if canCreateHouseholdModuleDoc("meals");
      allow update: if canUpdateHouseholdModuleDoc("meals");
      allow delete: if canDeleteHouseholdModuleDoc("meals");
    }

    match /mealTemplates/{docId} {
      allow read: if canReadHouseholdModuleDoc("meals");
      allow create: if canCreateHouseholdModuleDoc("meals");
      allow update: if canUpdateHouseholdModuleDoc("meals");
      allow delete: if canDeleteHouseholdModuleDoc("meals");
    }

    match /familyLists/{docId} {
      allow read: if canReadHouseholdModuleDoc("lists");
      allow create: if canCreateHouseholdModuleDoc("lists");
      allow update: if canUpdateHouseholdModuleDoc("lists");
      allow delete: if canDeleteHouseholdModuleDoc("lists");
    }

    match /familyListItems/{docId} {
      allow read: if canReadHouseholdModuleDoc("lists");
      allow create: if canCreateHouseholdModuleDoc("lists");
      allow update: if canUpdateHouseholdModuleDoc("lists");
      allow delete: if canDeleteHouseholdModuleDoc("lists");
    }

    match /familyPantryItems/{docId} {
      allow read: if canReadHouseholdModuleDoc("lists");
      allow create: if canCreateHouseholdModuleDoc("lists");
      allow update: if canUpdateHouseholdModuleDoc("lists");
      allow delete: if canDeleteHouseholdModuleDoc("lists");
    }

    match /groceries/{docId} {
      allow read: if canReadHouseholdModuleDoc("lists");
      allow create: if canCreateHouseholdModuleDoc("lists");
      allow update: if canUpdateHouseholdModuleDoc("lists");
      allow delete: if canDeleteHouseholdModuleDoc("lists");
    }

    match /children/{docId} {
      allow read: if canReadHouseholdModuleDoc("home");
      allow create: if hasRequestFamilyId() && canManageFamily(requestFamilyId());
      allow update: if hasRequestFamilyId()
        && hasExistingFamilyId()
        && requestFamilyId() == existingFamilyId()
        && canManageFamily(existingFamilyId());
      allow delete: if hasExistingFamilyId() && canManageFamily(existingFamilyId());
    }

    match /familyMembers/{docId} {
      allow read: if canReadHouseholdDoc() || isOwnFamilyMemberRecord(resource.data);
      allow create: if hasRequestFamilyId() && canManageFamily(requestFamilyId());
      allow update: if hasRequestFamilyId()
        && hasExistingFamilyId()
        && requestFamilyId() == existingFamilyId()
        && canManageFamily(existingFamilyId());
      allow delete: if hasExistingFamilyId() && canManageFamily(existingFamilyId());
    }

    match /familyActivity/{docId} {
      allow read: if canReadAnyScopedDoc();
      allow create: if canCreateActivityDoc();
      allow update: if false;
      allow delete: if canReadAnyScopedDoc();
    }

    match /notifications/{notificationId} {
      allow read: if canReadNotificationDoc();
      allow create: if canCreateNotificationDoc();
      allow update: if canUpdateOwnNotification();
      allow delete: if canReadNotificationDoc();
    }

    match /mail/{mailId} {
      allow create: if signedIn()
        && request.resource.data.get("createdBy", "") == request.auth.uid
        && request.resource.data.get("status", "") == "queued";
      allow read, update, delete: if false;
    }

    match /familyInvitations/{docId} {
      allow read: if canReadHouseholdDoc()
        || (signedIn() && cleanString(resource.data.get("recipientEmail", "")).lower() == userEmail());
      allow create: if hasRequestFamilyId()
        && canManageFamily(requestFamilyId())
        && request.resource.data.get("createdBy", "") == request.auth.uid;
      allow update: if canReadHouseholdDoc()
        || (signedIn() && cleanString(resource.data.get("recipientEmail", "")).lower() == userEmail());
      allow delete: if hasExistingFamilyId() && canManageFamily(existingFamilyId());
    }

    match /custodyGroups/{groupId} {
      allow read: if canReadCustody(groupId);
      allow create: if hasRequestFamilyId()
        && canManageFamily(requestFamilyId())
        && request.resource.data.get("ownerId", "") == request.auth.uid
        && request.resource.data.get("createdBy", "") == request.auth.uid;
      allow update: if canManageCustody(groupId);
      allow delete: if canManageCustody(groupId);
    }

    match /custodyInvitations/{docId} {
      allow read: if canReadCustodyDoc()
        || (signedIn() && cleanString(resource.data.get("recipientEmail", "")).lower() == userEmail());
      allow create: if canCreateCustodyDoc()
        && request.resource.data.get("createdBy", "") == request.auth.uid;
      allow update: if canUpdateCustodyDoc()
        || (signedIn() && cleanString(resource.data.get("recipientEmail", "")).lower() == userEmail());
      allow delete: if canDeleteCustodyDoc();
    }

    match /custodyDays/{docId} {
      allow read: if canReadCustodyDoc();
      allow create: if canCreateCustodyDoc();
      allow update: if canUpdateCustodyDoc();
      allow delete: if canDeleteCustodyDoc();
    }

    match /custodySpecialEvents/{docId} {
      allow read: if canReadCustodyDoc();
      allow create: if canCreateCustodyDoc();
      allow update: if canUpdateCustodyDoc();
      allow delete: if canDeleteCustodyDoc();
    }

    match /custodyTravelPlans/{docId} {
      allow read: if canReadCustodyDoc();
      allow create: if canCreateCustodyDoc();
      allow update: if canUpdateCustodyDoc();
      allow delete: if canDeleteCustodyDoc();
    }

    match /custodyExchanges/{docId} {
      allow read: if canReadCustodyDoc();
      allow create: if canCreateCustodyDoc();
      allow update: if canUpdateCustodyDoc();
      allow delete: if canDeleteCustodyDoc();
    }

    match /custodyPackingItems/{docId} {
      allow read: if canReadCustodyDoc();
      allow create: if canCreateCustodyDoc();
      allow update: if canUpdateCustodyDoc();
      allow delete: if canDeleteCustodyDoc();
    }

    match /custodyExpenses/{docId} {
      allow read: if hasExistingCustodyGroupId() && canReadBudget(existingCustodyGroupId());
      allow create: if hasRequestCustodyGroupId() && canWriteBudget(requestCustodyGroupId());
      allow update: if hasRequestCustodyGroupId()
        && hasExistingCustodyGroupId()
        && requestCustodyGroupId() == existingCustodyGroupId()
        && canWriteBudget(existingCustodyGroupId());
      allow delete: if hasExistingCustodyGroupId() && canWriteBudget(existingCustodyGroupId());
    }

    match /custodyNotificationPrefs/{scopeId} {
      allow read: if canReadCustody(scopeId) || canReadCustodyDoc();
      allow create, update: if canCreateCustodyDoc() || canUpdateCustodyDoc();
      allow delete: if canManageCustody(scopeId) || canDeleteCustodyDoc();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
